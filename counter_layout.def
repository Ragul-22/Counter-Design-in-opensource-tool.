        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 500710 999757 ) N ;
    - count[3] + NET count[3] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 501630 999757 ) N ;
    - rst_n + NET rst_n + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 498870 999757 ) N ;
END PINS
NETS 13 ;
    - _00_ ( _08_ A ) ( _06_ B ) ( _05_ Y ) + USE SIGNAL ;
    - _01_ ( _08_ SLEEP ) ( _07_ Y ) + USE SIGNAL ;
    - _02_[0] ( _10_ D ) ( _04_ Y ) + USE SIGNAL ;
