        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 502550 999757 ) N ;
    - count[0] + NET count[0] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 499790 999757 ) N ;
    - count[1] + NET count[1] + DIRECTION OUTPUT + USE SIGNAL
