    - count[0] ( PIN count[0] ) ( _10_ Q ) ( _09_ A ) ( _07_ A1 ) ( _05_ B ) ( _04_ A ) + USE SIGNAL ;
    - count[1] ( PIN count[1] ) ( _11_ Q ) ( _09_ B ) ( _07_ A2 ) ( _05_ C ) + USE SIGNAL ;
